  @State currentQuestion: string = "";
  @State textSize: number = 22;
  @State userAnswer: string = "";
  @State isThinking: boolean = false;

  aboutToAppear() {
    this.showRandomQuestion();
  }

  // 显示随机灵魂拷问
  private showRandomQuestion() {
    const randomIndex = Math.floor(Math.random() * this.questions.length);
    this.currentQuestion = this.questions[randomIndex];
    this.textSize = 22;
    this.isThinking = false;
    this.userAnswer = "";
  }

  // 处理答案提交
  private handleAnswerSubmit() {
    console.log("用户答案:", this.userAnswer);

    // 显示提示消息
    promptAction.showToast({
      message: "灵魂在问答间得到了洗礼~",
      duration: 2000
    });

    // 清空文本框
    this.userAnswer = "";

    // 返回功能汇总页面
    this.backToAdjustPage();
  }

  // 返回功能汇总页面
  private backToAdjustPage() {
    this.pageStack.pop();
  }

  // 构建问题显示区域
  @Builder
  private buildQuestionArea() {
    Column() {
      // 思考图标
      Image($r('app.media.ic_soul_question'))
        .width(80)
        .height(80)
        .objectFit(ImageFit.Contain)
        .margin({ bottom: 20 })
        .opacity(this.isThinking ? 1 : 0.7)
        .fillColor($r('app.color.soul_icon'))

      // 问题内容
      Text(this.currentQuestion)
        .fontSize(this.textSize)
        .fontColor($r('app.color.soul_question_text'))
        .textAlign(TextAlign.Center)
        .lineHeight(35)
        .padding(20)
        .backgroundColor($r('app.color.soul_question_background'))
        .borderRadius(15)
        .shadow({ radius: 5, color: '#40000000', offsetX: 2, offsetY: 2 })
    }
    .width('100%')
    .height('40%')
    .justifyContent(FlexAlign.Center)
    .alignItems(HorizontalAlign.Center)
    .onClick(() => {
      // 点击文字放大效果和思考动画
      this.textSize = this.textSize === 22 ? 26 : 22;
      this.isThinking = !this.isThinking;
    })
  }

  // 构建答案输入区域
  @Builder
  private buildAnswerArea() {
    Column() {
      TextArea({
        text: this.userAnswer,
        placeholder: "静下心来，写下你内心真实的回答..."
      })
        .height(200)
        .width('90%')
        .fontSize(18)
        .fontColor($r('app.color.soul_input_text'))
        .placeholderColor($r('app.color.soul_placeholder'))
        .backgroundColor($r('app.color.soul_input_background'))
        .border({ width: 1, color: $r('app.color.soul_input_border') })
        .borderRadius(10)
        .padding(15)
        .textAlign(TextAlign.Start)
        .onChange((value: string) => {
          this.userAnswer = value;
        })
        .margin({ bottom: 20 })

      Button('完成回答')
        .width(200)
        .height(50)
        .backgroundColor($r('app.color.soul_button_primary'))
        .fontColor($r('app.color.soul_button_text'))
        .fontSize(20)
        .borderRadius(25)
        .onClick(() => this.handleAnswerSubmit())
        .shadow({ radius: 5, color: '#40000000', offsetX: 2, offsetY: 2 })
    }
    .width('100%')
    .padding(20)
    .justifyContent(FlexAlign.Start)
    .alignItems(HorizontalAlign.Center)
  }

  // 构建控制面板
  @Builder
  private buildControlPanel() {
    Column() {
      Button('换一个问题')
        .width(200)
        .height(50)
        .backgroundColor($r('app.color.soul_button_secondary'))
        .fontColor($r('app.color.soul_button_text'))
        .fontSize(20)
        .borderRadius(25)
        .onClick(() => {
          this.userAnswer = "";
          this.showRandomQuestion();
        })
        .margin({ bottom: 15 })
    }
    .width('100%')
    .alignItems(HorizontalAlign.Center)
  }

