            .margin({ left: 15 })
            .onClick(() => this.backToAdjustPage())
            .fillColor($r('app.color.soul_nav_icon'))

          Text('灵魂拷问')
            .fontSize(20)
            .fontWeight(FontWeight.Bold)
            .fontColor($r('app.color.soul_nav_title'))
            .margin({ left: 20 })

          Blank()
        }
        .width('100%')
        .height(90)
        .backgroundColor($r('app.color.soul_nav_background'))
        .border({ width: { bottom: 1 }, color: $r('app.color.soul_nav_border') })
        .margin({ top: -20 })
        .expandSafeArea([SafeAreaType.SYSTEM], [SafeAreaEdge.TOP, SafeAreaEdge.BOTTOM])

        // 问题显示区域
        this.buildQuestionArea()

        // 答案输入区域
        this.buildAnswerArea()

        // 控制面板
        this.buildControlPanel()
      }
      .width('100%')
      .height('100%')
      .backgroundColor($r('app.color.soul_background'))
      .expandSafeArea([SafeAreaType.SYSTEM], [SafeAreaEdge.TOP, SafeAreaEdge.BOTTOM])
    }
    .onReady((context: NavDestinationContext) => {
      this.pageStack = context.pathStack;
    })
    .hideTitleBar(true)
  }
}

@Builder
export function SoulQuestionPageBuilder(param: object) {
  SoulQuestionPage()
}