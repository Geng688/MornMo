  // 切换课程
  private changeClass(index: number): void {
    this.currentClassIndex = index;
    this.hasChange = !this.hasChange; // 强制重新渲染
  }

  // 构建序号按钮
  @Builder
  private buildClassButton(title: string, index: number) {
    Column() {
      Text(title)
        .fontSize(16)
        .fontColor(this.currentClassIndex === index ? $r('app.color.class_button_selected_text') : $r('app.color.class_button_text'))
        .fontWeight(FontWeight.Bold)
        .padding(10)
        .width(60)
        .height(60)
        .textAlign(TextAlign.Center)
        .backgroundColor(this.currentClassIndex === index ? $r('app.color.class_button_selected') : $r('app.color.class_button_background'))
        .borderRadius(30)
        .border({ width: 2, color: this.currentClassIndex === index ? $r('app.color.class_button_selected') : $r('app.color.class_button_border') })
    }
    .margin({ right: 10 })
    .onClick(() => {
      this.changeClass(index);
    })
  }

  // 构建课程内容
  @Builder
  private buildClassContent(classItem: EmotionClassItem): void {
    Column() {
      // 课程标题
      Text(classItem.title)
        .fontSize(24)
        .fontColor($r('app.color.class_title'))
        .fontWeight(FontWeight.Bold)
        .margin({ bottom: 20 })
        .textAlign(TextAlign.Center)
        .width('100%')

      // 课程内容部分
      ForEach(classItem.sections, (section: ClassSection) => {
        Column() {
          Text(section.title)
            .fontSize(20)
            .fontColor($r('app.color.class_section_title'))
            .fontWeight(FontWeight.Bold)
            .margin({ bottom: 10 })

          Text(section.content)
            .fontSize(18)
            .fontColor($r('app.color.class_section_content'))
            .lineHeight(30)
        }
        .padding(15)
        .width('100%')
        .margin({ bottom: 15 })
        .backgroundColor($r('app.color.class_section_background'))
        .borderRadius(10)
        .shadow({ radius: 3, color: '#10000000', offsetX: 0, offsetY: 2 })
      })
    }
    .padding(20)
    .width('100%')
  }

  build() {
    Column() {
      // 顶部标题
      /*Text('情绪课堂系列：13 堂实用情绪调节课')
        .fontSize(28)
        .fontColor($r('app.color.class_main_title'))
        .fontWeight(FontWeight.Bold)
        .margin({ top: 20, bottom: 20 })
        .textAlign(TextAlign.Center)
        .width('100%')*/

      // 序号按钮区域
      Scroll() {
        Row() {
          ForEach(this.classTitles, (title: string, index: number) => {
            this.buildClassButton(title, index)
          })
        }
        .padding({ left: 20, right: 20 })
        .justifyContent(FlexAlign.Start)
      }
      .scrollable(ScrollDirection.Horizontal)
      .height(80)
      .margin({ bottom: 20 })
      .edgeEffect(EdgeEffect.Spring)

      // 内容区域
      Scroll() {
        if (this.hasChange == true) {
          this.buildClassContent(this.emotionClasses[this.currentClassIndex])
        }
        else{
          this.buildClassContent(this.emotionClasses[this.currentClassIndex])
        }
      }
      .layoutWeight(1)
      .padding({ left: 10, right: 10 })
      .edgeEffect(EdgeEffect.Spring)
    }
    .width('100%')
    .height('100%')
    .backgroundColor($r('app.color.class_background'))
    .expandSafeArea([SafeAreaType.SYSTEM], [SafeAreaEdge.TOP, SafeAreaEdge.BOTTOM])
  }
}

@Builder
export function EmotionClassPageBuilder(param: object) {
  EmotionClassPage()
