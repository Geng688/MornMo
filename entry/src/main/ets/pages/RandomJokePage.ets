  @State currentJoke: string = "";
  @State textSize: number = 20;
  @State isLaughing: boolean = false;

  aboutToAppear() {
    this.showRandomJoke();
  }

  // 显示随机笑话
  private showRandomJoke() {
    const randomIndex = Math.floor(Math.random() * this.jokes.length);
    this.currentJoke = this.jokes[randomIndex];
    this.textSize = 20;
    this.isLaughing = false;
  }

  // 返回功能汇总页面
  private backToAdjustPage() {
    this.pageStack.pop();
  }

  // 构建笑话显示区域
  @Builder
  private buildJokeArea() {
    Column() {
      // 笑脸图标
      Text('😆')
        .fontSize(40)
        .margin({ bottom: 15 })

      // 笑话内容
      Text(this.currentJoke)
        .fontSize(this.textSize)
        .fontColor($r('app.color.joke_text'))
        .textAlign(TextAlign.Center)
        .padding(20)
        .backgroundColor($r('app.color.joke_card_background'))
        .borderRadius(15)
        .shadow({ radius: 5, color: '#40000000', offsetX: 2, offsetY: 2 })
    }
    .width('100%')
    .height('60%')
    .justifyContent(FlexAlign.Center)
    .alignItems(HorizontalAlign.Center)
    .onClick(() => {
      // 点击文字放大效果和笑脸动画
      this.textSize = this.textSize === 20 ? 24 : 20;
      this.isLaughing = !this.isLaughing;
    })
  }

  // 构建控制面板
  @Builder
  private buildControlPanel() {
    Column() {
      // 刷新按钮
      Button('再笑一个')
        .width(200)
        .height(50)
        .backgroundColor($r('app.color.joke_button_background'))
        .fontColor($r('app.color.joke_button_text'))
        .fontSize(20)
        .borderRadius(25)
        .onClick(() => this.showRandomJoke())
        .margin({ bottom: 20 })

      // 分享按钮（注释掉的部分保持原样）
      /*Button('分享笑话')
        .width(200)
        .height(50)
        .backgroundColor('#4CAF50')
        .fontColor(Color.White)
        .fontSize(20)
        .borderRadius(25)
        .onClick(() => this.shareJoke())*/
    }
    .width('100%')
    .alignItems(HorizontalAlign.Center)
  }

  // 分享笑话功能
  private shareJoke() {
    // 这里可以添加分享逻辑
    console.log('分享笑话：' + this.currentJoke);
  }

  build() {
    NavDestination() {
      Column() {
        // 顶部导航栏
        Row() {
          Image($r('app.media.ic_back'))
            .width(30)
            .height(30)
            .margin({ left: 15 })
            .onClick(() => this.backToAdjustPage())

          Text('随机笑话')
            .fontSize(20)
            .fontWeight(FontWeight.Bold)
            .fontColor($r('app.color.joke_nav_title'))
            .margin({ left: 20 })

          Blank()
        }
        .width('100%')
        .height(90)
        .backgroundColor($r('app.color.joke_nav_background'))
        .border({ width: { bottom: 1 }, color: $r('app.color.joke_nav_border') })
        .margin({ top: -20 })
        .expandSafeArea([SafeAreaType.SYSTEM], [SafeAreaEdge.TOP, SafeAreaEdge.BOTTOM])

        // 笑话显示区域
        this.buildJokeArea()

        // 控制面板
        this.buildControlPanel()
      }
      .width('100%')
      .height('100%')
      .backgroundColor($r('app.color.joke_background'))
      .expandSafeArea([SafeAreaType.SYSTEM], [SafeAreaEdge.TOP, SafeAreaEdge.BOTTOM])
    }
    .onReady((context: NavDestinationContext) => {
      this.pageStack = context.pathStack;
    })
    .hideTitleBar(true)
  }
}

