  @State currentQuote: string = "";
  @State author: string = "";
  @State textSize: number = 22;
  @State isHighlighted: boolean = false;

  aboutToAppear() {
    this.showRandomQuote();
  }

  // 显示随机名言
  private showRandomQuote() {
    const randomIndex = Math.floor(Math.random() * this.quotes.length);
    const fullQuote = this.quotes[randomIndex];
    const parts = fullQuote.split(" — ");

    this.currentQuote = parts[0];
    this.author = parts.length > 1 ? "— " + parts[1] : "";
    this.textSize = 22;
    this.isHighlighted = false;
  }

  // 返回功能汇总页面
  private backToAdjustPage() {
    this.pageStack.pop();
  }

  // 构建名言显示区域
  @Builder
  private buildQuoteArea() {
    Column() {
      // 引号图标
      Row() {
        Text('"')
          .fontSize(40)
          .fontColor($r('app.color.quote_mark'))
          .fontWeight(FontWeight.Bold)
      }
      .width('100%')
      .justifyContent(FlexAlign.Start)
      .margin({ bottom: 10 })

      // 名言内容
      Text(this.currentQuote)
        .fontSize(this.textSize)
        .fontColor(this.isHighlighted ? $r('app.color.quote_text_highlight') : $r('app.color.quote_text_normal'))
        .textAlign(TextAlign.Center)
        .fontStyle(FontStyle.Italic)
        .lineHeight(35)
        .padding({ left: 20, right: 20 })

      // 作者信息
      Text(this.author)
        .fontSize(18)
        .fontColor($r('app.color.quote_author'))
        .textAlign(TextAlign.End)
        .margin({ top: 20 })
        .width('90%')

      // 结束引号
      Row() {
        Text('"')
          .fontSize(40)
          .fontColor($r('app.color.quote_mark'))
          .fontWeight(FontWeight.Bold)
      }
      .width('100%')
      .justifyContent(FlexAlign.End)
      .margin({ top: 10 })
    }
    .width('90%')
    .height('50%')
    .justifyContent(FlexAlign.Center)
    .alignItems(HorizontalAlign.Center)
    .padding(25)
    .margin({ top: 60 })
    .backgroundColor($r('app.color.quote_card_background'))
    .borderRadius(20)
    .shadow({ radius: 8, color: '#40000000', offsetX: 3, offsetY: 3 })
    .onClick(() => {
      this.textSize = this.textSize === 22 ? 24 : 22;
      this.isHighlighted = !this.isHighlighted;
    })
  }

  // 构建控制面板
  @Builder
  private buildControlPanel() {
    Column() {
      // 刷新按钮
      Button('下一条名言')
        .width(200)
        .height(50)
        .backgroundColor($r('app.color.quote_button_primary'))
        .fontColor($r('app.color.quote_button_text'))
        .fontSize(20)
        .borderRadius(25)
        .onClick(() => this.showRandomQuote())
        .margin({ bottom: 15, top: 30 })

      // 复制按钮（注释掉的部分保持原样）
      /*Button('复制名言')
        .width(200)
        .height(50)
        .backgroundColor('#42A5F5')
        .fontColor(Color.White)
        .fontSize(20)
        .borderRadius(25)
        .onClick(() => this.copyQuote())*/
    }
    .width('100%')
    .alignItems(HorizontalAlign.Center)
  }

  // 复制名言功能
  private copyQuote() {
    console.log('复制名言：' + this.currentQuote);
  }

  build() {
    NavDestination() {
      Column() {
        // 顶部导航栏
        Row() {
          Image($r('app.media.ic_back'))
            .width(30)
            .height(30)
            .margin({ left: 15 })
            .onClick(() => this.backToAdjustPage())

          Text('名人名言')
            .fontSize(20)
            .fontWeight(FontWeight.Bold)
            .fontColor($r('app.color.quote_nav_title'))
            .margin({ left: 20 })

          Blank()
        }
        .width('100%')
        .height(90)
        .backgroundColor($r('app.color.quote_nav_background'))
        .border({ width: { bottom: 1 }, color: $r('app.color.quote_nav_border') })
        .margin({ top: -20 })
        .expandSafeArea([SafeAreaType.SYSTEM], [SafeAreaEdge.TOP, SafeAreaEdge.BOTTOM])

        // 名言显示区域
        this.buildQuoteArea()

        // 控制面板
        this.buildControlPanel()
      }
      .width('100%')
      .height('100%')
      .backgroundColor($r('app.color.quote_background'))
      .expandSafeArea([SafeAreaType.SYSTEM], [SafeAreaEdge.TOP, SafeAreaEdge.BOTTOM])
    }
    .onReady((context: NavDestinationContext) => {
      this.pageStack = context.pathStack;
    })
    .hideTitleBar(true)
  }
}

@Builder
export function RandomQuotePageBuilder(param: object) {
  RandomQuotePage()
