  }

  // 显示随机故事
  private showRandomStory() {
    const randomIndex = Math.floor(Math.random() * this.stories.length);
    this.currentStory = this.stories[randomIndex];
    this.textSize = 18;
    this.isExpanded = false;
  }

  // 返回功能汇总页面
  private backToAdjustPage() {
    this.pageStack.pop();
  }

  // 构建故事显示区域
  @Builder
  private buildStoryArea() {
    Column() {
      // 故事书图标
      Image($r('app.media.ic_book'))
        .width(60)
        .height(60)
        .objectFit(ImageFit.Contain)
        .margin({ bottom: 15 })

      // 故事内容
      Scroll() {
        Text(this.currentStory)
          .fontSize(this.textSize)
          .fontColor($r('app.color.story_text'))
          .textAlign(TextAlign.Start)
          .lineHeight(30)
      }
      .width('90%')
      .height(this.isExpanded ? '1000px' : '800px')
      .padding(20)
      .backgroundColor($r('app.color.story_content_background'))
      .borderRadius(15)
      .shadow({ radius: 5, color: '#40000000', offsetX: 2, offsetY: 2 })
    }
    .width('100%')
    .height('65%')
    .justifyContent(FlexAlign.Center)
    .alignItems(HorizontalAlign.Center)
    .onClick(() => {
      this.textSize = this.textSize === 18 ? 20 : 18;
      this.isExpanded = !this.isExpanded;
    })
  }

  // 构建控制面板
  @Builder
  private buildControlPanel() {
    Column() {
      // 刷新按钮
      Button('下一个故事')
        .width(200)
        .height(50)
        .backgroundColor($r('app.color.story_button_primary'))
        .fontColor($r('app.color.story_button_text'))
        .fontSize(20)
        .borderRadius(25)
        .onClick(() => this.showRandomStory())
        .margin({ bottom: 15 })

      // 收藏按钮（注释掉的部分保持原样）
      /*Button('收藏故事')
        .width(200)
        .height(50)
        .backgroundColor('#8D6E63')
        .fontColor(Color.White)
        .fontSize(20)
        .borderRadius(25)
        .onClick(() => this.saveStory())*/
    }
    .width('100%')
    .alignItems(HorizontalAlign.Center)
  }

  // 收藏故事功能
  private saveStory() {
    console.log('收藏故事：' + this.currentStory.substring(0, 20) + '...');
  }

  build() {
    NavDestination() {
      Column() {
        // 顶部导航栏
        Row() {
          Image($r('app.media.ic_back'))
            .width(30)
            .height(30)
            .margin({ left: 15 })
            .onClick(() => this.backToAdjustPage())

          Text('随机故事')
            .fontSize(20)
            .fontWeight(FontWeight.Bold)
            .fontColor($r('app.color.story_nav_title'))
            .margin({ left: 20 })

          Blank()
        }
        .width('100%')
        .height(90)
        .backgroundColor($r('app.color.story_nav_background'))
        .border({ width: { bottom: 1 }, color: $r('app.color.story_nav_border') })
        .margin({ top: -20 })
        .expandSafeArea([SafeAreaType.SYSTEM], [SafeAreaEdge.TOP, SafeAreaEdge.BOTTOM])

        // 故事显示区域
        this.buildStoryArea()

        // 控制面板
        this.buildControlPanel()
      }
      .width('100%')
      .height('100%')
      .backgroundColor($r('app.color.story_background'))
      .expandSafeArea([SafeAreaType.SYSTEM], [SafeAreaEdge.TOP, SafeAreaEdge.BOTTOM])
    }
    .onReady((context: NavDestinationContext) => {
      this.pageStack = context.pathStack;
    })
    .hideTitleBar(true)
  }
}

@Builder
export function RandomStoryPageBuilder(param: object) {
  RandomStoryPage()
}