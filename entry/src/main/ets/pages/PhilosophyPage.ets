  // 构建左侧导航项
  @Builder
  private buildTabBarItem(item: PhilosophyItem, index: number) {
    Column() {
      Text(item.title)
        .fontSize(16)
        .fontColor(this.currentTabIndex === index ?
        $r('app.color.philosophy_tab_selected_text') :
        $r('app.color.philosophy_tab_unselected_text'))
        .fontWeight(this.currentTabIndex === index ? FontWeight.Bold : FontWeight.Medium)
        .padding(10)
        .width('100%')
        .textAlign(TextAlign.Center)
        .backgroundColor(this.currentTabIndex === index ?
        $r('app.color.philosophy_tab_selected_background') :
          'transparent')
        .borderRadius(8)
        .margin({ bottom: 5 })

      if (this.currentTabIndex === index) {
        Divider()
          .color($r('app.color.philosophy_tab_divider'))
          .strokeWidth(2)
          .width('70%')
          .margin({ top: 5 })
      }
    }
    .width('100%')
    .padding(5)
    .backgroundColor(this.currentTabIndex === index ?
    $r('app.color.philosophy_tab_container_selected') :
    $r('app.color.philosophy_tab_container_unselected'))
    .borderRadius(10)
    .border({
      width: this.currentTabIndex === index ? 1 : 0,
      color: $r('app.color.philosophy_tab_border')
    })
    .onClick(() => {
      this.currentTabIndex = index;
      this.hasChange = !this.hasChange;
    })
  }

  // 构建哲学内容
  @Builder
  private buildPhilosophyContent(item: PhilosophyItem): void {
    Column() {
      Text(item.title)
        .fontSize(24)
        .fontColor($r('app.color.philosophy_content_title'))
        .fontWeight(FontWeight.Bold)
        .margin({ bottom: 20 })
        .textAlign(TextAlign.Center)

      Divider()
        .color($r('app.color.philosophy_content_divider'))
        .strokeWidth(1)
        .margin({ bottom: 20 })

      Text(item.content)
        .fontSize(18)
        .fontColor($r('app.color.philosophy_content_text'))
        .lineHeight(32)
        .textAlign(TextAlign.Start)
    }
    .padding(25)
    .width('100%')
    .backgroundColor($r('app.color.philosophy_content_background'))
    .borderRadius(15)
    .border({ width: 1, color: $r('app.color.philosophy_content_border') })
    .shadow({ radius: 8, color: '#20660000', offsetX: 0, offsetY: 3 })
  }

  build() {
    Row() {
      // 左侧导航栏
      Scroll() {
        Column() {
          // 注释掉的导航标题保持原样
          /*Text('哲学思想')
            .fontSize(18)
            .fontColor('#2E7D32')
            .fontWeight(FontWeight.Bold)
            .padding(15)
            .width('100%')
            .textAlign(TextAlign.Center)
            .backgroundColor('#E8F5E9')
            .borderRadius(10)
            .margin({ bottom: 10 })*/

          ForEach(this.philosophyItems, (item: PhilosophyItem, index: number) => {
            this.buildTabBarItem(item, index)
          })
        }
        .width('100%')
        .padding({ top: 10, bottom: 10, left: 5, right: 5 })
      }
      .width(100)
      .backgroundColor($r('app.color.philosophy_nav_background'))
      .border({ width: { right: 2 }, color: $r('app.color.philosophy_nav_border') })
      .height('100%')
      .edgeEffect(EdgeEffect.Spring)

      // 右侧内容区域
      Scroll() {
        Column() {
          if (this.hasChange) {
            this.buildPhilosophyContent(this.philosophyItems[this.currentTabIndex])
          } else {
            this.buildPhilosophyContent(this.philosophyItems[this.currentTabIndex])
          }

          // 添加底部装饰
          Row() {
            Text('💭')
              .fontSize(20)
              .margin({ right: 10 })
            Text('哲学启迪智慧，思考照亮人生')
              .fontSize(14)
              .fontColor($r('app.color.philosophy_footer_text'))
              .fontStyle(FontStyle.Italic)
          }
          .justifyContent(FlexAlign.Center)
          .width('100%')
          .padding(15)
          .margin({ top: 20 })
          .backgroundColor($r('app.color.philosophy_footer_background'))
          .borderRadius(10)
        }
        .padding({ left: 20, right: 20, top: 15, bottom: 15 })
        .width('100%')
      }
      .layoutWeight(1)
      .scrollBar(BarState.On)
      .edgeEffect(EdgeEffect.Spring)
    }
    .width('100%')
    .height('100%')
    .backgroundColor($r('app.color.philosophy_background'))
  }
}

