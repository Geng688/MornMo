    核心原理：个体接收某一刺激（如批评、说服）的次数过多、强度过大、时间过长时，会从“接受”转向“反感”，甚至产生“逆反行为”。\
    \n\n经典故事：马克·吐温听牧师演讲时，起初想捐100元；演讲10分钟后，想捐50元；演讲30分钟后，决定不捐；演讲结束时，他反而从盘子里偷了2元。\
    生活延伸：父母反复唠叨孩子“要好好学习”，孩子会从“愧疚”变成“厌烦”，甚至故意不学习；这一效应提醒人们“沟通要适度，避免过度刺激”。'
    }
  ];

  // 构建左侧导航项
  @Builder
  private buildTabBarItem(category: string, index: number) {
    Column() {
      Text(category)
        .fontSize(16)
        .fontColor(this.currentTabIndex === index ? $r('app.color.psy_nav_selected_text') : $r('app.color.psy_nav_unselected_text'))
        .fontWeight(this.currentTabIndex === index ? FontWeight.Bold : FontWeight.Normal)
        .padding(10)
        .width('100%')
        .textAlign(TextAlign.Center)
        .backgroundColor(this.currentTabIndex === index ? $r('app.color.psy_nav_selected_bg') : 'transparent')

      if (this.currentTabIndex === index) {
        Divider()
          .color($r('app.color.psy_nav_divider'))
          .strokeWidth(2)
          .width('80%')
      }
    }
    .width('100%')
    .onClick(() => {
      this.currentTabIndex = index;
      this.hasChange = !this.hasChange;
    })
  }

  // 构建知识内容
  @Builder
  private buildKnowledgeContent(item: KnowledgeItem): void {
    Column() {
      Text(item.title)
        .fontSize(24)
        .fontColor($r('app.color.psy_title_text'))
        .fontWeight(FontWeight.Bold)
        .margin({ bottom: 20 })

      Text(item.content)
        .fontSize(18)
        .fontColor($r('app.color.psy_content_text'))
        .lineHeight(30)
    }
    .padding(20)
    .width('100%')
    .backgroundColor($r('app.color.psy_card_bg'))
    .borderRadius(15)
    .border({ width: 1, color: $r('app.color.psy_card_border') })
    .shadow({ radius: 5, color: '#20000000', offsetX: 0, offsetY: 2 })
  }

  build() {
    Row() {
      // 左侧导航栏
      Scroll() {
        Column() {
          ForEach(this.knowledgeCategories, (category: string, index: number) => {
            this.buildTabBarItem(category, index)
          })
        }
        .width('100%')
        .padding({ top: 10, bottom: 10 })
      }
      .width(100)
      .backgroundColor($r('app.color.psy_nav_bg'))
      .border({ width: { right: 1 }, color: $r('app.color.psy_nav_border') })
      .height('100%')
      .edgeEffect(EdgeEffect.Spring)

      // 右侧内容区域
      Scroll() {
        if (this.hasChange == true) {
          Column() {
            this.buildKnowledgeContent(this.knowledgeContent[this.currentTabIndex])
          }
          .padding({ left: 20, right: 20 })
          .width('100%')
        } else {
          Column() {
            this.buildKnowledgeContent(this.knowledgeContent[this.currentTabIndex])
          }
          .padding({ left: 20, right: 20 })
          .width('100%')
        }
      }
      .layoutWeight(1)
      .edgeEffect(EdgeEffect.Spring)
    }
    .width('100%')
    .height('100%')
    .backgroundColor($r('app.color.psy_background'))
    .expandSafeArea([SafeAreaType.SYSTEM], [SafeAreaEdge.TOP, SafeAreaEdge.BOTTOM])
  }
}

@Builder
export function PsyKnowledgePageBuilder(param: object) {
  PsyKnowledgePage()
}